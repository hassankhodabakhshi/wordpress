{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "outDir": "./js/",            // پوشه‌ای که فایل‌های جاوااسکریپت در آن قرار می‌گیرد
    "rootDir": "./src/",         // پوشه‌ای که فایل‌های TypeScript در آن قرار دارد
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],    // شامل کردن فایل‌های TypeScript
  "exclude": ["node_modules"]     // نادیده گرفتن پوشه node_modules
}
